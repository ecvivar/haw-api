# Environment
NODE_ENV=development
PORT=8080

# Database (Neon PostgreSQL)
# 1. Create a free database at https://neon.tech
# 2. Copy the connection string (with ?sslmode=require)
# 3. Add &pgbouncer=true&connection_limit=5 for connection pooling
# 4. Set DATABASE_URL in Vercel Dashboard for production
# Local Docker: postgresql://postgres:postgres@localhost:5432/hawapi?schema=public
# Neon example: postgresql://user:pass@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require&pgbouncer=true&connection_limit=5
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/hawapi?schema=public"

# JWT (RS256) - Generate your own keys: node -e "const c=require('crypto');const{k,p}=c.generateKeyPairSync('rsa',{modulusLength:2048,publicKeyEncoding:{type:'spki',format:'pem'},privateKeyEncoding:{type:'pkcs8',format:'pem'}});console.log('JWT_PRIVATE_KEY=\"'+k.trim().replace(/\n/g,'\\n')+'\"\nJWT_PUBLIC_KEY=\"'+p.trim().replace(/\n/g,'\\n')+'\"')"
JWT_PRIVATE_KEY=""
JWT_PUBLIC_KEY=""
JWT_ISSUER="HawAPI"
JWT_AUDIENCE="http://localhost:8080/api/v1"

# API Config
API_TITLE="HawAPI"
API_DESCRIPTION="A Free and Open Source API for Stranger Things."
API_VERSION="1.2.0"
API_URL="http://localhost:8080"
API_PATH="/api"
API_VERSION_PATH="v1"
DEFAULT_LANGUAGE="en-US"
SUPPORTED_LANGUAGES="en-US,pt-BR"

# CORS
CORS_ORIGIN=*

# Rate Limiting
RATE_LIMIT_ANONYMOUS=16
RATE_LIMIT_BASIC=20
RATE_LIMIT_DEV=24
RATE_LIMIT_MAINTAINER=30
RATE_LIMIT_ADMIN=60
RATE_LIMIT_AUTH=3
RATE_LIMIT_AUTH_HOURS=12

# Registration
ENABLE_REGISTRATION=true

# Pagination
PAGE_MAX_SIZE=20
PAGE_DEFAULT_SIZE=10

# Frontend (Next.js) - copy to frontend/.env.local
# NEXT_PUBLIC_API_URL=http://localhost:8080

# Docker PostgreSQL
# To run: docker-compose up -d --build
# Then seed: npx prisma db push && npm run prisma:seed
# Default admin: admin / admin123
