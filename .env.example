# Environment
NODE_ENV=development
PORT=8080

# Database
# Local:       postgresql://postgres:admin@localhost:5432/hawapi?schema=public
# Vercel/Neon: postgresql://user:pass@ep-xxx.us-east-2.aws.neon.tech/hawapi?sslmode=require&pgbouncer=true&connection_limit=5
DATABASE_URL="postgresql://postgres:admin@localhost:5432/hawapi?schema=public"

# JWT (RS256) - Generate your own keys: node -e "const c=require('crypto');const{k,p}=c.generateKeyPairSync('rsa',{modulusLength:2048,publicKeyEncoding:{type:'spki',format:'pem'},privateKeyEncoding:{type:'pkcs8',format:'pem'}});console.log('JWT_PRIVATE_KEY=\"'+k.trim().replace(/\n/g,'\\n')+'\"\nJWT_PUBLIC_KEY=\"'+p.trim().replace(/\n/g,'\\n')+'\"')"
JWT_PRIVATE_KEY=""
JWT_PUBLIC_KEY=""
JWT_ISSUER="HawAPI"
JWT_AUDIENCE="http://localhost:8080/api/v1"

# API Config
API_TITLE="HawAPI"
API_DESCRIPTION="A Free and Open Source API for Stranger Things."
API_VERSION="1.2.0"
API_URL="http://localhost:8080"
API_PATH="/api"
API_VERSION_PATH="v1"
DEFAULT_LANGUAGE="en-US"
SUPPORTED_LANGUAGES="en-US,pt-BR"

# Rate Limiting
RATE_LIMIT_ANONYMOUS=16
RATE_LIMIT_BASIC=20
RATE_LIMIT_DEV=24
RATE_LIMIT_MAINTAINER=30
RATE_LIMIT_ADMIN=60
RATE_LIMIT_AUTH=3
RATE_LIMIT_AUTH_HOURS=12

# Registration
ENABLE_REGISTRATION=true

# Pagination
PAGE_MAX_SIZE=20
PAGE_DEFAULT_SIZE=10
